# Live Web 控制台 Docker 部署示例环境变量
# 复制为 .env 后由 docker compose 自动读取：cp .env.example .env

LIVE_CONSOLE_PUBLISH_PORT=8787
LIVE_AUTH_USERNAME=admin
LIVE_AUTH_PASSWORD=change-me-now
# 建议生产环境填写固定随机串，避免每次重启会话失效
LIVE_SESSION_SECRET=
WECOM_ENABLED=false
WECOM_WEBHOOK_URL=
ALLOW_LIVE_ORDERS=false
# 需要出网访问 OKX 公开行情时再设为 true
REFRESH_MARKET=false
